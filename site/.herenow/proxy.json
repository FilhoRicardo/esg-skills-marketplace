{
  "proxies": {
    "/api/intake/stage": {
      "upstream": "https://here.now/api/v1/drives/REPLACE_WITH_INTAKE_DRIVE_ID/files/uploads",
      "method": "POST",
      "rateLimit": "6/hour/ip",
      "headers": {
        "Authorization": "Bearer ${HERENOW_INTAKE_DRIVE_TOKEN}"
      }
    },
    "/api/intake/finalize": {
      "upstream": "https://here.now/api/v1/drives/REPLACE_WITH_INTAKE_DRIVE_ID/files/finalize",
      "method": "POST",
      "rateLimit": "6/hour/ip",
      "headers": {
        "Authorization": "Bearer ${HERENOW_INTAKE_DRIVE_TOKEN}"
      }
    }
  }
}
