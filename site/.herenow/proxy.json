{
  "proxies": {
    "/api/intake/submit": {
      "upstream": "https://api.github.com/repos/FilhoRicardo/esg-skills-marketplace/actions/workflows/site-submission-intake.yml/dispatches",
      "method": "POST",
      "rateLimit": "6/hour/ip",
      "headers": {
        "Authorization": "Bearer ${GITHUB_INTAKE_TOKEN}",
        "Accept": "application/vnd.github+json",
        "X-GitHub-Api-Version": "2022-11-28"
      }
    }
  }
}
